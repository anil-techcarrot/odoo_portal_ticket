<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Email template for new internal users -->
        <record id="portal_send_invite_email" model="mail.template">
            <field name="name">Settings: New Portal User Invite Custom</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">Advanced notification : Employee Self Service Portal Account Set-up</field>
            <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to" eval="False"/>
            <field name="use_default_to" eval="True"/>
            <field name="description">Sent to new user after you invited them</field>
            <field name="body_html" type="html">
<t>
    <table border="0" cellpadding="0" cellspacing="0"
           style="padding-top:16px; background-color:#FFFFFF; font-family:Verdana, Arial, sans-serif; color:#454748; width:100%; border-collapse:separate;">
        <tr>
            <td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="590"
                       style="padding:16px; background-color:#FFFFFF; color:#454748; border-collapse:separate;">
                    <tbody>


                        <!-- CONTENT -->
                        <tr>
                            <td align="center">
                                <table border="0" cellpadding="0" cellspacing="0" width="590"
                                       style="background-color:white; padding:0px 8px;">
                                    <tr>
                                        <td style="font-size:13px; line-height:1.6;">
                                            <div>
                                                Dear <t t-out="object.name or ''"/> ,<br/><br/>

                                                Welcome to <b><span style="border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#008000;border-bottom-color:#008000;border-right-color:#008000;border-top-color:#008000;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: green; font-weight: bold;">tech</span><span style="border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#ff0000;border-bottom-color:#ff0000;border-right-color:#ff0000;border-top-color:#ff0000;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: red; font-weight: bold;">carrot</span>’s Employee Self Service Portal!</b><br/><br/>

                                                This is an advance notification to inform you that your account is in the process of being created on our newly launched HRIS platform.<br/><br/>

                                                Your access to the new HRIS platform is SSO-enabled and your login ID is
                                                <b><t t-out="object.email or ''"/></b><br/><br/>

                                                You will receive a follow-up email from Team HR with detailed instructions on how to access the portal.<br/><br/>

                                                Thank you for your patience and cooperation.<br/><br/>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:center;">
                                            <hr style="background-color:#CCCCCC; border:none; height:1px; margin:16px 0;"/>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>

                        <!-- FOOTER -->
                        <tr>
                            <td align="center">
                                <table border="0" cellpadding="0" cellspacing="0" width="590"
                                       style="background-color:white; font-size:11px; padding:0px 8px;">
                                    <tr>
                                        <td>
                                            <t t-out="object.company_id.name or ''"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="opacity:0.7;">
                                            <t t-out="object.company_id.phone or ''"/>
                                            <t t-if="object.company_id.email">
                                                | <a t-att-href="'mailto:%s' % object.company_id.email"
                                                     style="color:#454748;">
                                                    <t t-out="object.company_id.email"/>
                                                </a>
                                            </t>
                                            <t t-if="object.company_id.website">
                                                | <a t-att-href="object.company_id.website"
                                                     style="color:#454748;">
                                                    <t t-out="object.company_id.website"/>
                                                </a>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </td>
        </tr>
    </table>
</t>
</field>



        </record>

    </data>
</odoo>
