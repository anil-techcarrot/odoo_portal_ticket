<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_payroll.action_report_payslip" model="ir.actions.report">
        <field name="print_report_name">
            object._get_report_name()
        </field>
    </record>
    <template id="report_payslip_custom" inherit_id="hr_payroll.report_payslip">
        <xpath expr="//strong[@id='invalid_warning']" position="replace">
            <strong id="invalid_warning" class="d-none">
                <span t-out="is_invalid">This payslip is not validated. This is not a legal document.</span>
            </strong>
        </xpath>
        <xpath expr="//h2[@id='payslip_name']" position="replace">
            <t t-set="report_name" t-value="o._get_report_name()"/>
            <h2 id="payslip_name">
                <span t-out="report_name">August 2023 Payslip</span>
            </h2>
        </xpath>
        <xpath expr="//div[@id='employee_job_position']" position="replace">
            <div id="employee_job_position" t-if="o.version_id.job_id" style="display:none">
                <strong class="me-2">Job Position:</strong>
                <span t-field="o.version_id.job_id"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='employee_id']" position="replace">
            <div id="employee_id">
                <strong class="me-2">Employee Code:</strong>
                <span t-if="o.employee_id.emp_code" t-field="o.employee_id.emp_code"/>
                <span t-else="" style="color:#875A7B" class="fw-bold">No ID !!!</span>
            </div>
            <t t-if="o.company_id.currency_id.name == 'INR'">
                <div id="pf_account">
                    <strong class="me-2">PF A/c No:</strong>
                    <span t-field="o.employee_id.pf_number"/>
                </div>
                <div id="uan_number">
                    <strong class="me-2">UAN:</strong>
                    <span t-field="o.employee_id.uan"/>
                </div>

            </t>
        </xpath>
        <xpath expr="//div[@id='employee_email']" position="replace">
            <div id="employee_email" t-if="o.employee_id.work_email" style="display:none;">
                <strong class="me-2">Email:</strong>
                <span t-field="o.employee_id.work_email"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='contract_type']" position="replace">
            <div id="contract_type" t-if="o.version_id.contract_type_id" style="display:none;">
                <strong class="me-2">Contract Type:</strong>
                <span t-field="o.version_id.contract_type_id"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='employee_marital']" position="replace">
            <div id="employee_marital" style="display:none;">
                <strong class="me-2">Marital Status:</strong>
                <span t-field="o.employee_id.marital"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='wage']" position="replace">
            <div id="wage" style="display:none;">
                <strong class="me-2">Contract Wage (<span class="text-capitalize" t-out="o.version_id.wage_type"/>):
                </strong>
                <span t-out="o.version_id._get_contract_wage()"
                      t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"
                      style="color:#875A7B" class="fw-bold"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='computed_on']" position="replace">
            <div id="computed_on" style="display:none;">
                <strong class="me-2">Computed On:</strong>
                <span t-field="o.compute_date"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='pay_period']" position="replace">
            <div id="date_of_joining">
                <strong class="me-2">Date of Joining:</strong>
                <span t-if="o.employee_id.emp_code" t-field="o.employee_id.doj"/>
                <span t-else="" style="color:#875A7B" class="fw-bold">No DOJ !!!</span>
            </div>
            <div id="pay_period" style="display:none;">
                <strong class="me-2">Pay Period:</strong>
                <span t-if="o.date_from &lt; o.version_id.contract_date_start"
                      t-field="o.version_id.contract_date_start"/>
                <span t-else="" t-field="o.date_from"/>
                -
                <span t-if="o.version_id.contract_date_end and o.date_to &gt; o.version_id.contract_date_end"
                      t-field="o.version_id.contract_date_end"/>
                <span t-else="" t-field="o.date_to"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='contract_start']" position="replace">
            <div id="contract_start" style="display:none;">
                <strong class="me-2">Contract Start Date:</strong>
                <span t-field="o.version_id.contract_date_start"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='working_schedule']" position="replace">
            <div id="working_schedule" style="display:none;">
                <strong class="me-2">Working Schedule:</strong>
                <span t-field="o.employee_id.version_id.hours_per_week"/>
                Hours / Week
            </div>
        </xpath>
        <!--            <xpath expr="//div[@id='wage']" position="before">-->
        <!--                <div id="employee_department" t-if="o.employee_id.department_id">-->
        <!--                    <strong class="me-2">Department:</strong>-->
        <!--                    <span t-field="o.employee_id.department_id"/>-->
        <!--                </div>-->
        <!--            </xpath>-->
        <xpath expr="//div[@id='contract_start']" position="after">
            <t t-if="o.company_id.currency_id.name == 'INR'">
                <div id="pan_number">
                    <strong class="me-2">PAN:</strong>
                    <span t-if="o.employee_id.pan" t-field="o.employee_id.pan"/>
                    <span t-else="" style="color:#875A7B" class="fw-bold">No PAN</span>
                </div>
            </t>
            <div id="designation">
                <strong class="me-2">Designation:</strong>
                <span t-field="o.employee_id.job_id.name"/>
                <span t-field="o.employee_id.job_title"/>
            </div>
            <!-- Calculate unpaid leave days -->
            <t t-set="unpaid_days"
               t-value="sum(o.worked_days_line_ids.filtered(lambda l: l.code in ['OUT', 'LEAVE90']).mapped('number_of_days'))"/>
            <!-- Calculate total days in payslip period -->
            <t t-set="total_days"
               t-value="(o.date_to - o.date_from).days + 1"/>
            <!-- Calculate paid days -->
            <t t-set="paid_days"
               t-value="total_days - unpaid_days"/>
            <div id="salary_paid_days">
                <strong class="me-2">Net Paid Days:</strong>
                <span t-esc="paid_days"/>
                Days
            </div>
        </xpath>
        <xpath expr="//div[@id='employee_department']" position="replace">
            <div id="employee_department" t-if="o.employee_id.department_id" style="display:none;">
                <strong class="me-2">Department:</strong>
                <span t-field="o.employee_id.department_id"/>
            </div>
        </xpath>

        <xpath expr="//div[@id='worked_days_table']" position="replace">
            <div id="worked_days_table" style="display: none;">
                <table class="table table-sm table-borderless">
                    <thead class="o_black_border">
                        <tr>
                            <th id="work_days_header_name">Earnings</th>
                            <th id="work_days_header_hours" class="text-end">Hours</th>
                            <th id="work_days_header_days" class="text-end">Days</th>
                            <th id="work_days_header_amount" class="text-end">Amount</th>
                            <th id="work_days_header_ytd" t-if="o.ytd_computation" class="text-end">YTD</th>
                        </tr>
                    </thead>
                    <tbody id="worked_days_lines">
                        <t t-set="worked_days_lines"
                           t-value="o.worked_days_line_ids.filtered(lambda worked_days: worked_days.code != 'OUT')"/>
                        <span t-foreach="worked_days_lines" t-as="worked_days">
                            <tr style="color:none">
                                <td id="worked_days_name">
                                    <span t-field="worked_days.name"/>
                                </td>
                                <td id="worked_days_hours" class="text-end">
                                    <span t-out="round(worked_days.number_of_hours, 2)"/>
                                </td>
                                <td id="worked_days_days" class="text-end">
                                    <span t-out="round(worked_days.number_of_days, 2)"/>
                                </td>
                                <td id="worked_days_amount" class="text-end">
                                    <span t-out="worked_days.amount" digits="[42, 2]"
                                          t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                                <td id="worked_days_ytd" t-if="o.ytd_computation" class="text-end">
                                    <span t-esc="worked_days.ytd"
                                          t-options="{'widget': 'monetary', 'display_currency': o.company_id.currency_id}"/>
                                </td>
                            </tr>
                        </span>
                        <span>
                            <t t-set="line_style" t-value="'color:#875A7B;'"/>
                            <t t-set="line_class" t-value="'o_total o_border_bottom fw-bold'"/>
                            <tr style="color:none">
                                <td t-att-class="line_class" t-att-style="line_style">
                                    <span>Total</span>
                                </td>
                                <td id="worked_days_total_hours" t-attf-class="#{line_class} text-end"
                                    t-att-style="line_style">
                                    <span t-out="round(sum(worked_days_lines.mapped('number_of_hours')), 2)"/>
                                </td>
                                <td id="worked_days_total_days" t-attf-class="#{line_class} text-end"
                                    t-att-style="line_style">
                                    <span t-out="round(sum(worked_days_lines.mapped('number_of_days')), 2)"/>
                                </td>
                                <td id="worked_days_total_amount" t-attf-class="#{line_class} text-end"
                                    t-att-style="line_style">
                                    <span t-out="sum(worked_days_lines.mapped('amount'))" digits="[42, 2]"
                                          t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                                <td id="worked_days_total_ytd" t-if="o.ytd_computation"
                                    t-attf-class="#{line_class} text-end" t-att-style="line_style">
                                    <span t-out="sum(worked_days_lines.mapped('ytd'))" digits="[42, 2]"
                                          t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                </td>
                            </tr>
                        </span>
                    </tbody>
                </table>
            </div>
        </xpath>
        <xpath expr="//div[@id='payslip_lines_table']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//div[@id='payslip_lines_table']" position="after">
            <div id="custom_payslip_lines_table">

                <!-- Prepare Data -->
                <t t-set="pay_line_ids" t-value="o.line_ids.filtered(lambda line: line.appears_on_payslip)"/>
                <t t-set="alw_line_ids"
                   t-value="pay_line_ids.filtered(lambda l: l.category_id.code != 'DED' and l.category_id.code != 'NET')"/>
                <t t-set="ded_line_ids" t-value="pay_line_ids.filtered(lambda l: l.category_id.code == 'DED')"/>

                <t t-set="alw_length" t-value="len(alw_line_ids)"/>
                <t t-set="ded_length" t-value="len(ded_line_ids)"/>
                <t t-set="max_length" t-value="max(alw_length, ded_length)"/>

                <t t-set="alw_amount" t-value="0"/>
                <t t-set="ded_amount" t-value="0"/>

                <!-- Table -->
                <table class="table table-sm" style="border: 2px solid black; width: 100%;">

                    <!-- Header -->
                    <thead>
                        <tr style="border: 2px solid black;">
                            <th colspan="2" class="text-center" style="border-right: 2px solid black;">
                                <b>Earnings</b>
                            </th>
                            <th colspan="2" class="text-center">
                                <b>Deductions</b>
                            </th>
                        </tr>
                    </thead>

                    <!-- Body -->
                    <tbody>

                        <!-- Loop -->
                        <t t-foreach="range(max_length)" t-as="i">
                            <tr>

                                <!-- Earnings -->
                                <td style="width:30%; padding-left:5px; border-right:1px solid black;">
                                    <t t-if="i &lt; alw_length">
                                        <span t-field="alw_line_ids[i].name"/>
                                    </t>
                                </td>

                                <td style="width:20%; padding-right:5px; border-right:2px solid black;"
                                    class="text-end">
                                    <t t-if="i &lt; alw_length">
                                        <t t-set="alw_amount" t-value="alw_amount + alw_line_ids[i].total"/>
                                        <span t-esc="'{:,.2f}'.format(alw_line_ids[i].total)"/>
                                    </t>
                                </td>

                                <!-- Deductions -->
                                <td style="width:30%; padding-left:5px; border-right:1px solid black;">
                                    <t t-if="i &lt; ded_length">
                                        <span t-field="ded_line_ids[i].name"/>
                                    </t>
                                </td>

                                <td style="width:20%; padding-right:5px;" class="text-end">
                                    <t t-if="i &lt; ded_length">
                                        <t t-set="ded_amount" t-value="ded_amount + ded_line_ids[i].total"/>
                                        <span t-esc="'{:,.2f}'.format(ded_line_ids[i].total)"/>
                                    </t>
                                </td>

                            </tr>
                        </t>

                        <!-- Totals Row -->
                        <tr style="border: 2px solid black;">
                            <td style="padding-left:5px; border-right:1px solid black;">
                                <b>Total Earnings</b>
                            </td>
                            <td style="padding-right:5px; border-right:2px solid black;" class="text-end">
                                <b>
                                    <span t-esc="'{:,.2f}'.format(alw_amount)"/>
                                </b>
                            </td>

                            <td style="padding-left:5px; border-right:1px solid black;">
                                <b>Total Deductions</b>
                            </td>
                            <td style="padding-right:5px;" class="text-end">
                                <b>
                                    <span t-esc="'{:,.2f}'.format(ded_amount)"/>
                                </b>
                            </td>
                        </tr>

                        <!-- Net Salary Row -->
                        <tr>
                            <td colspan="3" style="text-align:right; padding-right:10px;">
                                <b>Net Salary</b>
                            </td>
                            <td style="border: 2px solid black; padding-right:5px;" class="text-end">
                                <b>
                                    <span t-field="o.net_wage"/>
                                </b>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
        </xpath>
        <xpath expr="//div[@id='to_pay']" position="after">
            <strong>Amount in Words:</strong>
            <span t-esc="o.get_amount_in_words(o.net_wage)"/>
            <br></br>
            <br></br>
            <span>This is a system generated document &amp; does not require a signature.</span>
        </xpath>
    </template>

    <template id="external_layout_standard" inherit_id="web.external_layout_standard">
        <div t-attf-class="footer o_company_#{company.id}_layout {{report_type != 'pdf' and 'mt-auto'}}"
             position="replace">
            <div t-attf-class="footer o_company_#{company.id}_layout {{report_type != 'pdf' and 'mt-auto'}}">
                <div class="o_footer_content d-flex border-top pt-2">
                    <div class="flex-grow-1 text-start me-2" t-field="company.report_footer"/>
                    <div class="text-end text-muted">
                        <!--                        <div t-if="report_type == 'pdf' and display_name_in_footer" t-out="o.name">(document name)</div>-->
                        <!--                        <div t-if="report_type == 'pdf'">Page <span class="page"/> / <span class="topage"/></div>-->
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>

