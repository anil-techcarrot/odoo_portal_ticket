<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_employee_crm_notes_modal" name="CRM Notes Modal Content">
      <!-- FIXED: wrapped content in modal / modal-dialog / modal-content
           so the JS querySelector('.modal') can find and display it -->
      <div class="modal fade" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
          <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-sticky-note-o"></i>
                    Notes for <t t-esc="lead.name"/>
                </h5>
                <!-- FIXED: added close (X) button with Bootstrap 5 attribute -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <t t-if="notes">
                    <div class="list-group">
                        <t t-foreach="notes" t-as="note">
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <div class="mb-1">
                                        <strong t-esc="note.author_id.name or 'System'"/>
                                    </div>
                                    <small t-esc="note.date.strftime('%B %d, %Y at %I:%M %p')" class="text-muted"/>
                                </div>
                                <!-- FIXED: t-esc -> t-raw, note.body is stored as HTML -->
                                <div class="note-content" t-raw="note.body" style="white-space: pre-wrap; margin-top: 10px;"/>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-if="not notes">
                    <div class="alert alert-info text-center">
                        <i class="fa fa-info-circle"></i>
                        No notes found for this lead.
                    </div>
                </t>
            </div>
            <div class="modal-footer">
                <!-- FIXED: data-dismiss (Bootstrap 4) -> data-bs-dismiss (Bootstrap 5) -->
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>
    </template>
</odoo>