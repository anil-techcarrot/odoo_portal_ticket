<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        These are the ORIGINAL 5 ticket types that existing tickets reference.
        We UPDATE them in place (same XML IDs) to add category_id.
        NEVER delete these — existing it.ticket records reference their DB IDs.
    -->
    <data noupdate="0">
        <record id="type_hardware" model="it.ticket.type">
            <field name="name">Hardware Issue</field>
            <field name="code">hardware_issue</field>
            <field name="category_id" ref="ticketing_it.cat_hardware"/>
            <field name="sequence">10</field>
        </record>
        <record id="type_software" model="it.ticket.type">
            <field name="name">Software Issue</field>
            <field name="code">software_issue</field>
            <field name="category_id" ref="ticketing_it.cat_software"/>
            <field name="sequence">10</field>
        </record>
        <record id="type_social" model="it.ticket.type">
            <field name="name">Youtube/Instagram/Facebook/X/WhatsApp</field>
            <field name="code">social_media</field>
            <field name="category_id" ref="ticketing_it.cat_social_media"/>
            <field name="sequence">10</field>
        </record>
        <record id="type_network" model="it.ticket.type">
            <field name="name">Network Issue</field>
            <field name="code">network_issue</field>
            <field name="category_id" ref="ticketing_it.cat_network"/>
            <field name="sequence">10</field>
        </record>
        <record id="type_other" model="it.ticket.type">
            <field name="name">Other</field>
            <field name="code">other</field>
            <field name="sequence">99</field>
        </record>
    </data>
</odoo>