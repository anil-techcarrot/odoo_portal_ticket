<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_server_auto_submit_portal" model="ir.actions.server">
        <field name="name">IT Ticket: Auto Submit for Portal Users</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="state">code</field>
        <field name="code">
if env.user.has_group('base.group_portal'):
    record.action_submit()
        </field>
    </record>

    <record id="action_auto_submit_portal" model="base.automation">
        <field name="name">IT Ticket: Auto Submit for Portal Users</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(4, ref('action_server_auto_submit_portal'))]"/>
        <field name="active">True</field>
    </record>
</odoo>
