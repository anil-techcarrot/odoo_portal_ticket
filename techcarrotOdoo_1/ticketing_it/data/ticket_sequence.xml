<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence configuration for generating unique IT ticket numbers -->
        <record id="seq_it_tickets" model="ir.sequence">
            <field name="name">IT Ticket Sequence</field>
            <field name="code">it.ticket</field>
            <field name="prefix">TKT/%(year)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>