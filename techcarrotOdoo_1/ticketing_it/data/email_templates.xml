<odoo>
    <data noupdate="0">

        <!-- 1. Manager Approval -->
        <record id="email_template_manager_approval" model="mail.template">
            <field name="name">IT Ticket - Manager Approval</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Action Required: IT Ticket Approval</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #2c3e50; padding: 15px; border-radius: 5px;">
                                    <h2 style="color: white; margin: 0;">IT Ticket - Approval Required</h2>
                                </div>
                    <p>Dear <strong><t t-esc="object.line_manager_id.name"/></strong>,</p>

                    <p>An IT ticket requires your approval.</p>

                    <table border="1" cellpadding="6" cellspacing="0" width="100%">
                        <tr style="background-color: #f2f2f2;"><td><b>Ticket</b></td><td><t t-esc="object.name"/></td></tr>
                        <tr><td><b>Subject</b></td><td><t t-esc="object.subject"/></td></tr>
                        <tr style="background-color: #f2f2f2;"><td><b>Employee</b></td><td><t t-esc="object.employee_id.name"/></td></tr>
                        <tr><td><b>Priority</b></td><td><t t-esc="object.priority"/></td></tr>
                        <tr style="background-color: #f2f2f2;"><td><b>Required By</b></td>
                            <td><t t-esc="object.required_date and object.required_date.strftime('%d-%m-%Y') or 'Not specified'"/></td>
                        </tr>
                    </table>

                    <p>Please approve or reject this ticket.</p>
                    <!-- ✅ BUTTON -->
                    <t t-set="base_url" t-value="env['ir.config_parameter'].sudo().get_param('web.base.url')"/>

                    <p style="text-align:center; margin-top:20px;">
                        <a t-att-href="base_url + '/web#id=%s&model=it.ticket&view_type=form' % object.id"
                           style="background-color:#2c3e50
                           ; color:white; padding:10px 20px; text-decoration:none; border-radius:5px;">
                            View Ticket
                        </a>
                    </p>
                </div>
            ]]></field>
        </record>

