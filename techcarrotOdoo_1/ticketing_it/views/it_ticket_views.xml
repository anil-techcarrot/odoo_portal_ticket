<!--        <field name="name">Pending Category Manager Approval</field>-->
<!--        <field name="res_model">it.ticket</field>-->
<!--        <field name="view_mode">list,form</field>-->
<!--        <field name="domain">[('state','=','category_manager_approval'), ('category_manager_id', '=', uid)]</field>-->
<!--        <field name="context">{}</field>-->
<!--    </record>-->

    <record id="action_it_ticket_pending_it" model="ir.actions.act_window">
        <field name="name">Pending IT Approval</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','it_approval')]</field>
        <field name="context">{}</field>
    </record>

</odoo>