<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <record id="group_it_manager" model="res.groups">
        <field name="name">IT Manager</field>
    </record>

    <record id="group_it_team" model="res.groups">
        <field name="name">IT Support Team</field>
    </record>

    <record id="group_line_manager" model="res.groups">
        <field name="name">Line Manager</field>
    </record>

    <!-- ================================================
         PORTAL USER: own tickets + line manager + it manager
         (Line Manager branch excludes Level-0 tickets — he's never part of that
          flow, even if line_manager_id happens to be populated on the record.
          IT Manager branch scoped to Level-2 tickets that have reached his
          stage, or that he rejected — same logic as the backend rule below)
    ================================================ -->
    <record id="rule_it_ticket_portal" model="ir.rule">
        <field name="name">Portal: Own Tickets + Line Manager + IT Manager</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="domain_force">['|', '|', ('employee_id.user_id', '=', user.id),
            '&amp;', ('line_manager_id', '=', user.id), ('workflow_level', '!=', '0'),
            '&amp;', '&amp;', ('it_manager_id', '=', user.id), ('workflow_level', '=', '2'),
            '|', ('state', 'in', ['it_approval', 'assigned', 'in_progress', 'done']),
            '&amp;', ('state', '=', 'rejected'), ('rejected_by_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================
         LINE MANAGER (internal): sees their team tickets at all stages,
         EXCEPT Level-0 tickets — those never involve him at all, even if
         line_manager_id got populated on the record.
    ================================================ -->
    <record id="rule_it_ticket_line_manager" model="ir.rule">
        <field name="name">Line Manager: See team tickets at all stages</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="domain_force">[('line_manager_id', '=', user.id), ('workflow_level', '!=', '0')]</field>
        <field name="groups" eval="[(4, ref('ticketing_it.group_line_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================
         IT MANAGER (internal): sees ONLY Level-2 tickets, and ONLY once the
         ticket has actually reached IT-approval stage (i.e. Line Manager has
         already approved) — never before, never for Level 0/1/3 tickets.
    ================================================ -->
    <record id="rule_it_ticket_it_manager" model="ir.rule">
        <field name="name">IT Manager: Tickets pending IT approval</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="domain_force">['&amp;', '&amp;', ('it_manager_id', '=', user.id), ('workflow_level', '=', '2'),
            '|', ('state', 'in', ['it_approval', 'assigned', 'in_progress', 'done']),
            '&amp;', ('state', '=', 'rejected'), ('rejected_by_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('ticketing_it.group_it_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ================================================
         IT TEAM: sees only assigned tickets
    ================================================ -->
    <record id="rule_it_ticket_it_team" model="ir.rule">
        <field name="name">IT Team: Only assigned tickets</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="domain_force">[('assigned_to_id', '=', user.id), ('state', 'in', ['assigned', 'in_progress',
            'done'])]
        </field>
        <field name="groups" eval="[(4, ref('ticketing_it.group_it_team'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================
         CROSS-COMPANY: IT Manager and IT Support can read
         hr.employee records across companies
    ================================================ -->
    <record id="rule_hr_employee_it_manager_cross_company" model="ir.rule">
        <field name="name">IT Manager: Read employees across companies</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('ticketing_it.group_it_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>


    <!-- HR Reviewer: sees only tickets pending HR approval -->
    <record id="rule_it_ticket_hr_manager" model="ir.rule">
        <field name="name">HR Reviewer: Tickets pending HR approval</field>
        <field name="model_id" ref="model_it_ticket"/>
        <field name="domain_force">[('state', '=', 'hr_approval')]</field>
        <field name="groups" eval="[(4, ref('employee_profile_change_request.group_profile_change_hr_reviewer'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_hr_employee_it_team_cross_company" model="ir.rule">
        <field name="name">IT Support: Read employees across companies</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('ticketing_it.group_it_team'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>