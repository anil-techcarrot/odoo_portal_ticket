<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
<!--        Tree view for Compliance Projects.-->
        <record id="view_compliance_project_tree" model="ir.ui.view">
            <field name="name">compliance.project.tree</field>
            <field name="model">compliance.project</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="year"/>
                    <field name="stage_id"/>
                    <field name="open_task_count"/>
                    <field name="closed_task_count"/>
                    <field name="tag_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

<!--Kanban view for Compliance Projects.-->
        <record id="view_compliance_project_kanban" model="ir.ui.view">
            <field name="name">compliance.project.kanban</field>
            <field name="model">compliance.project</field>
            <field name="arch" type="xml">
                <kanban default_group_by="stage_id"
                        class="o_kanban_small_column"
                        highlight_color="kanban_color"
                        group_create="false"
                        group_edit="false"
                        group_delete="false">
                    <field name="kanban_color"/>
                    <field name="is_favorite"/>
                    <field name="stage_id"/>
                    <field name="tag_ids"/>
                    <field name="open_task_count"/>
                    <field name="closed_task_count"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click o_kanban_record d-flex flex-column">

                                <div class="o_kanban_record_top d-flex justify-content-between align-items-start">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>

                                    <field name="is_favorite"
                                           widget="boolean_favorite"
                                           nolabel="1"/>
                                </div>

                                <div class="o_kanban_record_body mt-2">
                                    <div class="text-muted mb-1">
                                        <field name="year"/>
                                    </div>

                                    <div class="o_kanban_record_body">
                                        <field name="tag_ids" widget="many2many_tags"
                                               options="{'color_field': 'color'}"/>
                                    </div>
                                </div>

                                <div class="o_kanban_record_bottom mt-auto d-flex align-items-center">
                                    <div class="text-muted">
                                        <span>
                                            <field name="open_task_count"/>
                                            Open
                                        </span>
                                        <span class="ms-2">
                                            <field name="closed_task_count"/>
                                            Closed
                                        </span>
                                    </div>

                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

<!--Form view for Compliance Projects.-->
        <record id="view_compliance_project_form" model="ir.ui.view">
            <field name="name">compliance.project.form</field>
            <field name="model">compliance.project</field>
            <field name="arch" type="xml">
                <form string="Compliance Project">
                    <header>
                        <field name="stage_id" widget="statusbar" options="{'clickable': true}"/>
                    </header>

                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>

                            <group>
                                <field name="year"/>
                                <field name="tag_ids" widget="many2many_tags"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Tasks">
                                <field name="task_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="manager_id"/>
                                        <field name="due_on"/>
                                        <field name="complied_on"/>
                                        <field name="assignee_ids" widget="many2many_tags"/>
                                        <field name="location_id"/>
                                        <field name="company_id"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

<!--            Main action used to open Compliance Projects.-->
<!--            Default view is Kanban with access to the Form view.-->
        <record id="action_compliance_project" model="ir.actions.act_window">
            <field name="name">Compliance Projects</field>
            <field name="res_model">compliance.project</field>
            <field name="view_mode">kanban,form</field>
        </record>

        <!-- <menuitem id="menu_compliance_root"
                  name="Compliance Tracker"/> -->

        <menuitem id="menu_compliance_project"
                  name="Compliance Projects"
                  parent="menu_compliance_root"
                  action="action_compliance_project"
                  sequence="20">
        </menuitem>

    </data>
</odoo>
