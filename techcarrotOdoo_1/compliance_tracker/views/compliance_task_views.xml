<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
<!--        Tree view showing all compliance tasks in tabular format.-->
        <record id="view_compliance_task_tree" model="ir.ui.view">
            <field name="name">compliance.task.tree</field>
            <field name="model">compliance.task</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="location_id" optional="show"/>
                    <field name="manager_id" optional="show"/>
                    <field name="reporting_status" optional="show"/>
                    <field name="complied_on" optional="show"/>
                    <field name="due_on" optional="show"/>
                    <field name="legend"
                           widget="badge"
                           decoration-success="legend == 'on_time'"
                           decoration-muted="legend == 'pending'"
                           decoration-danger="legend == 'late'"
                           optional="show"/>

                    <field name="company_id" optional="show"/>
                    <field name="compliance_project_id" optional="show"/>
                    <field name="attachment_count" optional="show"/>
                    <field name="active" optional="show"/>
                    <field name="assignee_ids" widget="many2many_tags" optional="show"/>
                </list>

            </field>
        </record>

<!--        Form view used to create and edit a single compliance task.-->
        <record id="view_compliance_task_form" model="ir.ui.view">
            <field name="name">compliance.task.form</field>
            <field name="model">compliance.task</field>
            <field name="arch" type="xml">
                <form string="Compliance Task">
                    <header>
                        <field name="stage_id" widget="statusbar" options="{'clickable': true}" required="1"/>
                    </header>

                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="compliance_project_id"/>
                                <field name="location_id"/>
                                <field name="manager_id"/>
                            </group>

                            <group>
                                <field name="company_id"/>
                                <field name="due_on"/>
                                <field name="complied_on"/>
                                <field name="legend"/>
                                <field name="attachment_count" readonly="1"/>
                                <field name="active"/>
                            </group>
                        </group>

                        <group>
                            <field name="reporting_status"/>
                            <field name="assignee_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

<!--        Kanban view for task workflow visualization.-->
        <record id="view_compliance_task_kanban" model="ir.ui.view">
            <field name="name">compliance.task.kanban</field>
            <field name="model">compliance.task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="stage_id"
                        class="o_kanban_small_column o_kanban_project_tasks"
                        create="true"
                        quick_create="true"
                        group_create="false"
                        group_edit="false"
                        group_delete="false">
                    <field name="name"/>
                    <field name="is_favorite"/>
                    <field name="legend"/>
                    <field name="assignee_ids"/>
                    <field name="color"/>
                    <field name="due_on"/>

                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_color_#{record.color.raw_value || 0} oe_kanban_card oe_kanban_global_click d-flex flex-column">

                                <div class="o_kanban_record_top d-flex justify-content-between align-items-start">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>

                                    <field name="is_favorite" widget="boolean_favorite" nolabel="1"/>
                                </div>

                                <div class="o_kanban_record_body mt-2">
                                    <field name="legend"
                                           widget="badge"
                                           decoration-success="legend == 'on_time'"
                                           decoration-warning="legend == 'pending'"
                                           decoration-danger="legend == 'late'"/>
                                </div>

                                <div class="o_kanban_record_bottom mt-auto d-flex align-items-center">
                                    <div class="text-muted">
                                        <field name="due_on" widget="date"/>
                                    </div>

                                    <div class="ms-auto">
                                        <field name="assignee_ids" widget="many2many_avatar_user"/>
                                    </div>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

<!--        Pie chart displaying task distribution by assignees.-->
        <record id="view_compliance_task_graph" model="ir.ui.view">
            <field name="name">compliance.task.graph</field>
            <field name="model">compliance.task</field>
            <field name="arch" type="xml">
                <graph string="Tasks by Assignee" type="pie">
                    <field name="id" type="measure"/>
                    <field name="assignee_ids" type="row"/>
                </graph>
            </field>
        </record>

<!--        Search view enabling filtering and grouping of tasks by company, location, stage, and due date.-->
        <record id="view_compliance_task_search" model="ir.ui.view">
            <field name="name">compliance.task.search</field>
            <field name="model">compliance.task</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="stage_id"/>
                    <field name="company_id"/>
                    <field name="location_id"/>

                    <separator/>

                    <filter name="group_company"
                            string="Company"
                            context="{'group_by': 'company_id'}"/>
                    <filter name="group_location"
                            string="Location"
                            context="{'group_by': 'location_id'}"/>
                    <filter name="group_due"
                            string="Due Date"
                            context="{'group_by': 'due_on'}"/>
                </search>
            </field>
        </record>

<!--        Main action opening the Compliance Task module.-->
<!--            Provides access to list, kanban, form, and graph views.-->
        <record id="action_compliance_task_main" model="ir.actions.act_window">
            <field name="name">Compliance Tracker</field>
            <field name="res_model">compliance.task</field>
            <field name="view_mode">list,kanban,form,graph</field>
        </record>



        <menuitem id="menu_compliance_root"
                  name="Compliance Tracker" web_icon="compliance_tracker,static/description/icon.png"/>

        <menuitem id="menu_compliance_task"
                  name="Compliance Tasks"
                  parent="menu_compliance_root"
                  action="action_compliance_task_main"
                  sequence="10"/>

    </data>
</odoo>
