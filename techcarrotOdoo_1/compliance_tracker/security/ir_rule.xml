<odoo>
    <data noupdate="0">
        <record id="rule_compliance_task_user" model="ir.rule">
            <field name="name">User: Personal Compliances Only</field>
            <field name="model_id" ref="model_compliance_task"/>
            <field name="groups" eval="[(4, ref('group_tccomplianceuser'))]"/>
            <field name="domain_force">[('assignee_ids', 'in', user.ids)]</field>
        </record>

        <record id="rule_compliance_admin_all" model="ir.rule">
            <field name="name">Admin: All Access</field>
            <field name="model_id" ref="model_compliance_task"/>
            <field name="groups" eval="[(4, ref('group_tccomplianceadmin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>